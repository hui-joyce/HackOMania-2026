# Backend .env Configuration Template
# Copy this file to .env and fill in your actual values

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
GOOGLE_APPLICATION_CREDENTIALS=./path/to/your/firebase-service-account-key.json

# Server Configuration
NODE_ENV=development
PORT=3000

# API Keys (using public endpoints)
# QUICKCHART_API_KEY is not required - using public endpoint https://quickchart.io/chart
# Google Cloud Storage
GCS_BUCKET_NAME=your-bucket-name
GCS_KEY_FILENAME=./gcs-service-account.json

# Groq Cloud API
GROQ_API_KEY=your-groq-api-key