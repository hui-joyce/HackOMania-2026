# Backend .env Configuration Template
# Copy this file to .env and fill in your actual values

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
# service account credentials 
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# API Keys
# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# Groq Cloud API
GROQ_API_KEY=your-groq-api-key

# HuggingFace API
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Google Cloud Storage
GCS_BUCKET_NAME=your-bucket-name
GCS_KEY_FILENAME=./gcs-service-account.json